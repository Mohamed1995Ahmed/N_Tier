@* Views/Employee/Index.cshtml *@
@using ManagementSystem.DAL.Models
@using ManagementSystem.BLL.ViemModels
@using ManagementSystem.PL.SharedResource
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

@model List<EmployeeDto>
@{
    ViewData["Title"] = Localizer["Employees"];
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">@Localizer["Employees"]</h2>
        <a asp-action="Add"
           asp-controller="Employee"
           class="btn btn-primary">
            @Localizer["AddEmployee"]
        </a>
    </div>
    <div class="card shadow border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>@Localizer["EmployeeName"]</th>
                        <th>@Localizer["DepartmentId"]</th>
                        <th>@Localizer["Salary"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.DepartmentId</td>
                            <td>@item.Salary</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>