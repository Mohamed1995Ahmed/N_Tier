@* Views/Department/Add.cshtml *@
@using ManagementSystem.BLL.ViemModels
@using ManagementSystem.PL.SharedResource
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

@model CreateDepartment
@{
    ViewData["Title"] = Localizer["AddDepartment1"];
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3>@Localizer["AddDepartment1"]</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Add"
                          asp-controller="Department"
                          method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">
                                @Localizer["DepartmentName"]
                            </label>
                            <input asp-for="Name"
                                   class="form-control form-control-lg" />
                            <span asp-validation-for="Name"
                                  class="text-danger"></span>
                        </div>
                        <div class="d-grid">
                            <button type="submit"
                                    class="btn btn-primary btn-lg">
                                @Localizer["AddDepartment"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}