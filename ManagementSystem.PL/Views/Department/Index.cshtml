@* Views/Department/Index.cshtml *@
@using ManagementSystem.DAL.Models
@using ManagementSystem.BLL.ViemModels
@using ManagementSystem.PL.SharedResource
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

@model List<DepartmentDto>
@{
    ViewData["Title"] = Localizer["Departments"];
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">@Localizer["Departments"]</h2>
        <a asp-action="Add"
           asp-controller="Department"
           class="btn btn-success">
            @Localizer["AddDepartment"]
        </a>
    </div>
    <div class="card shadow border-0">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-success">
                    <tr>
                        <th>@Localizer["DepartmentId"]</th>
                        <th>@Localizer["DepartmentName"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>